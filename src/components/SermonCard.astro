---
interface SermonData {
  title: string;
  speaker: string;
  event: string;
  summary: string;
  date: Date | string;
  locale: "en" | "zh";
  themes: string[];
  slug?: string;
  href?: string;
}

interface SermonEntryLike {
  id: string;
  data: SermonData;
}

interface Props {
  sermon: SermonData | SermonEntryLike;
}

const { sermon: rawSermon } = Astro.props;
const sermon =
  "data" in rawSermon
    ? {
        ...rawSermon.data,
        slug: rawSermon.id.split("/").slice(1).join("/")
      }
    : rawSermon;
const base = import.meta.env.BASE_URL;
const href =
  sermon.href ??
  (sermon.slug
    ? `${base}${sermon.locale}/sermons/${sermon.slug}/`
    : `${base}${sermon.locale}/sermons/`);

const date =
  sermon.date instanceof Date
    ? sermon.date.toLocaleDateString(sermon.locale === "zh" ? "zh-CN" : "en-US", {
        year: "numeric",
        month: "long",
        day: "numeric"
      })
    : sermon.date;
---

<article class="card card--sermon">
  <p class="eyebrow">{date}</p>
  <h3><a href={href}>{sermon.title}</a></h3>
  <p class="muted">{sermon.speaker} · {sermon.event}</p>
  <p>{sermon.summary}</p>
  <ul class="chip-list" aria-label="Themes">
    {sermon.themes.map((theme) => <li>{theme}</li>)}
  </ul>
</article>
