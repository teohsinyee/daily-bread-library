---
interface ArticleData {
  title: string;
  summary: string;
  date: Date | string;
  locale: "en" | "zh";
  themes: string[];
  slug?: string;
  href?: string;
}

interface ArticleEntryLike {
  id: string;
  data: ArticleData;
}

interface Props {
  article: ArticleData | ArticleEntryLike;
}

const { article: rawArticle } = Astro.props;
const article =
  "data" in rawArticle
    ? {
        ...rawArticle.data,
        slug: rawArticle.id.split("/").slice(1).join("/")
      }
    : rawArticle;
const base = import.meta.env.BASE_URL;
const href =
  article.href ??
  (article.slug
    ? `${base}${article.locale}/articles/${article.slug}/`
    : `${base}${article.locale}/articles/`);

const date =
  article.date instanceof Date
    ? article.date.toLocaleDateString(article.locale === "zh" ? "zh-CN" : "en-US", {
        year: "numeric",
        month: "long",
        day: "numeric"
      })
    : article.date;
---

<article class="card card--article">
  <p class="eyebrow">{date}</p>
  <h3><a href={href}>{article.title}</a></h3>
  <p>{article.summary}</p>
  <ul class="chip-list" aria-label="Themes">
    {article.themes.map((theme) => <li>{theme}</li>)}
  </ul>
</article>
